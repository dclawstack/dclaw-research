{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "DClaw Research",
  "version": "0.1.0",
  "identifier": "com.dclawstack.research",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && TAURI_BUILD=1 npm run build",
    "devUrl": "http://localhost:3012",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DClaw Research",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6ID...",
      "endpoints": [
        "https://releases.dclawstack.io/dclaw-research/latest.json"
      ]
    }
  }
}
